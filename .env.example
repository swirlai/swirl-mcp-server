# Required
SWIRL_BASE_URL=http://localhost:8000
SWIRL_USERNAME=<your-swirl-username>
SWIRL_PASSWORD=<your-swirl-password>

# Optional
SWIRL_VERIFY_SSL=true
SWIRL_TIMEOUT_SECONDS=30
SWIRL_RAG_TIMEOUT_SECONDS=60
SWIRL_MAX_RESULTS=50
# Comma-separated list of provider ids, names, or tags applied when a caller omits "providers"
# SWIRL_DEFAULT_PROVIDERS=arxiv,europe_pmc
